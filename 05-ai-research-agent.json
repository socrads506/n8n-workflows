    {
      "name": "Code: Get Next Pending",
      "type": "@n8n/n8n-nodes-base.code",
      "parameters": {
        "jsCode": "const items = $input.all();\nconst pending = items.filter(i => i.json.status === 'pending').slice(0, 3);\nreturn pending.length ? pending : [];"
      },
      "position": [
        440,
        0
      ],
      "typeVersion": 1.0,
      "id": "22a7573e-88d5-4453-91ea-c96e11b2fa3e"
    },
