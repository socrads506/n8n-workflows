    {
      "name": "AI: Summarize Findings",
      "type": "@n8n/n8n-nodes-base.openAi",
      "parameters": {
        "resource": "chat",
        "operation": "chat",
        "prompt": {
          "messages": [
            {
              "role": "system",
              "content": "Eres un research analyst experto. Vas a recibir resultados de b\u00fasqueda web y vas a escribir un resumen estructurado en espa\u00f1ol con:\n\n## Tema\n\n## Hallazgos Principales (3-5 puntos)\n\n## Datos Clave (con fuentes)\n\n## Implicaciones\n\n## Siguientes Preguntas\n\nS\u00e9 conciso, factual, y cita las fuentes de donde viene cada dato."
            },
            {
              "role": "user",
              "content": "={{'Tema: ' + $('Router: Research Tasks').first().json.topic + '\\n\\nResultados de b\u00fasqueda:\\n' + JSON.stringify($input.all().map(i => i.json), null, 2)}}"
            }
          ]
        },
        "options": {
          "temperature": 0.3
        }
      },
      "position": [
        1100,
        -100
      ],
      "typeVersion": 1.0,
      "id": "73cf8f37-abc9-4a3b-87fa-3d09814f690b"
    },
    {
      "name": "Code: Build Report",
      "type": "@n8n/n8n-nodes-base.code",
      "parameters": {
        "jsCode": "const task = $('Router: Research Tasks').first().json;\nconst summary = $input.first().json;\n\n return [{\n  json: {\n    topic: task.topic,\n    query: task.query,\n    report: summary.choices?.[0]?.message?.content || JSON.stringify(summary),\n    researched_at: new Date().toISOString(),\n    status: 'completed',\n    priority: task.priority\n  }\n}];"
      },
      "position": [
        1320,
        -100
      ],
      "typeVersion": 1.0,
      "id": "933e9fcd-7eed-4b1e-a820-ee27e989665c"
    },
    {
      "name": "Append to Knowledge Base (Drive)",
      "type": "@n8n/n8n-nodes-base.googleDrive",
      "parameters": {
        "operation": "upload",
        "fileName": "={{'Research-' + $json.topic.replace(/[^a-z0-9]/gi, '-') + '-' + $now.toISOString().split('T')[0] + '.md'}}",
        "fileContent": "={{$json.report}}",
        "folderId": {
          "__rl": true,
          "mode": "list",
          "value": ""
        },
        "options": {}
      },
      "position": [
